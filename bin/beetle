#!/usr/bin/env node
const { program } = require('commander');
const net = require('net');
const fs = require('fs');
const { SOCKET_PATH, parse, serialize } = require('../src/protocol');

program
  .name('beetle')
  .description('Beetle SSH Daemon CLI')
  .version('0.1.0');

function sendCommand(msg, callback) {
  const client = net.createConnection(SOCKET_PATH, () => {
    client.write(serialize(msg));
  });

  client.on('data', (data) => {
    const response = parse(data);
    callback(response);
    client.end();
  });

  client.on('error', (err) => {
    if (err.code === 'ENOENT') {
      console.error('Error: Daemon is not running. Start it with node src/daemon.js');
    } else {
      console.error('Error:', err.message);
    }
    process.exit(1);
  });
}

program
  .command('ping')
  .description('Ping the daemon')
  .action(() => {
    sendCommand({ type: 'ping' }, (res) => {
      console.log('Daemon response:', res.type === 'pong' ? 'PONG' : res);
    });
  });

program
  .command('ps')
  .description('List background sessions')
  .action(() => {
    sendCommand({ type: 'ps' }, (res) => {
      if (res.sessions.length === 0) {
        console.log('No active sessions.');
      } else {
        console.table(res.sessions);
      }
    });
  });

program
  .command('exec <command...>')
  .description('Execute a command in the background')
  .action((command) => {
    const fullCommand = command.join(' ');
    sendCommand({ type: 'exec', command: fullCommand }, (res) => {
      console.log(`Started session ${res.session.id} for command: ${res.session.command}`);
    });
  });

program
  .command('count-start')
  .description('Starts a simple loop counter in the background')
  .action(() => {
    const counterScript = path.join(__dirname, '../src/counter.js');
    const stateFile = '/tmp/beetle-test-counter.txt';
    const fullCommand = `node ${counterScript} ${stateFile}`;
    sendCommand({ type: 'exec', command: fullCommand }, (res) => {
      console.log(`Counter started in background session ${res.session.id}. State saved to ${stateFile}`);
    });
  });

program
  .command('count-status')
  .description('Check the status of the background counter')
  .action(() => {
    const stateFile = '/tmp/beetle-test-counter.txt';
    try {
      if (fs.existsSync(stateFile)) {
        const count = fs.readFileSync(stateFile, 'utf8');
        console.log(`The counter is currently at second: ${count}`);
      } else {
        console.log('Counter state file not found. Have you run "count-start" yet?');
      }
    } catch (err) {
      console.error('Error reading counter status:', err.message);
    }
  });

program
  .command('new_ssh <route> <alias>')
  .description('Register a new SSH configuration')
  .action(async (route, alias) => {
    const { addSshConfig } = require('../src/config-store');
    const id = Date.now().toString(); // Generate simple automatic ID
    try {
      await addSshConfig({ id, route, alias });
      console.log(`Successfully registered SSH config: ${alias} (ID: ${id}) for route ${route}`);
    } catch (err) {
      console.error('Failed to register new SSH config:', err.message);
    }
  });

program
  .command('ssh_list')
  .description('List all registered SSH configurations')
  .action(async () => {
    const { listSshConfigs } = require('../src/config-store');
    try {
      const sshs = await listSshConfigs();
      if (!sshs || sshs.length === 0) {
        console.log('No SSH configurations registered.');
      } else {
        console.table(sshs);
      }
    } catch (err) {
      console.error('Failed to list SSH configs:', err.message);
    }
  });

program
  .command('remove_ssh <id>')
  .description('Remove an SSH server from the records and secure vault')
  .action(async (id) => {
    const { removeSshConfig } = require('../src/config-store');
    const { deleteEnv } = require('../src/secret-store');
    try {
      await removeSshConfig(id);
      await deleteEnv(id);
      console.log(`Successfully removed SSH config with ID '${id}' and cleaned its secure secrets.`);
    } catch (err) {
      console.error('Failed to remove SSH config:', err.message);
      process.exit(1);
    }
  });

program
  .command('set_sudo <id>')
  .description('Set the super user password for an SSH config')
  .action(async (id) => {
    const { getSshConfig } = require('../src/config-store');
    const { getEnv, setEnv } = require('../src/secret-store');
    
    try {
      const config = await getSshConfig(id);
      if (!config) {
        console.error(`Error: SSH configuration with ID '${id}' not found.`);
        return;
      }
      
      const { default: password } = await import('@inquirer/password');
      const pass = await password({
        message: `Enter super user password for ${config.alias} (${config.route}):`,
        mask: '*'
      });
      
      let envObj = await getEnv(id);
      if (!envObj) envObj = {};
      envObj.SUPER_USER_PASSWORD = pass;
      
      await setEnv(id, envObj);
      console.log(`Successfully saved super user password for ID '${id}'.`);
      process.exit(0);
    } catch (err) {
      console.error('Failed to set sudo password:', err.message);
      process.exit(1);
    }
  });

program
  .command('create_session <alias>')
  .description('Connects and creates an SSH session in the background')
  .action((alias) => {
    sendCommand({ type: 'create_session', alias }, (res) => {
      if (res.type === 'error') {
        console.error('Failed:', res.message);
      } else {
        console.log(`SSH Session attempt started. Status: ${res.session.status} (ID: ${res.session.id})`);
      }
    });
  });

program
  .command('read_session <id>')
  .description('Read the output log of a given SSH session')
  .action((id) => {
    sendCommand({ type: 'read_session', id }, (res) => {
      if (res.type === 'error') {
        console.error('Error:', res.message);
      } else {
        console.log(res.output || '(No output recorded yet)');
      }
    });
  });

program
  .command('write <id> <input...>')
  .description('Write a command to an SSH session and read output')
  .action((id, inputArr) => {
    const input = inputArr.join(' ');
    sendCommand({ type: 'write', id, input }, (res) => {
      if (res.type === 'error') {
        console.error('Error:', res.message);
      } else {
        console.log(res.output || '(No output)');
      }
    });
  });

program
  .command('write_q <id> <input...>')
  .description('Write a command to an SSH session quietly')
  .action((id, inputArr) => {
    const input = inputArr.join(' ');
    sendCommand({ type: 'write_q', id, input }, (res) => {
      if (res.type === 'error') {
        console.error('Error:', res.message);
      } else {
        console.log('Command sent quietly.');
      }
    });
  });

program
  .command('send_key <id> <key>')
  .description('Send a special key combination (like ctrl+c) to a session')
  .action((id, key) => {
    const keyMap = {
      'ctrl+c': '\x03',
      'ctrl+d': '\x04',
      'ctrl+z': '\x1A',
      'ctrl+l': '\x0C',
      'esc': '\x1B',
      'enter': '\x0D'
    };
    
    const hexKey = keyMap[key.toLowerCase()];
    if (!hexKey) {
      console.error(`Error: Unknown key mapping '${key}'. Available keys: ${Object.keys(keyMap).join(', ')}`);
      process.exit(1);
    }

    sendCommand({ type: 'send_key', id, key: hexKey }, (res) => {
      if (res.type === 'error') {
        console.error('Error:', res.message);
      } else {
        console.log(`Key '${key}' sent successfully.`);
      }
    });
  });

const { spawn } = require('child_process');
const path = require('path');

program
  .command('start-daemon')
  .description('Start the beetle daemon in the background')
  .action(() => {
    const daemonPath = path.join(__dirname, '../src/daemon.js');
    const out = fs.openSync('/tmp/beetle-daemon.log', 'a');
    const err = fs.openSync('/tmp/beetle-daemon.log', 'a');

    const child = spawn('node', [daemonPath], {
      detached: true,
      stdio: ['ignore', out, err]
    });

    child.unref();
    console.log(`Daemon started in background (PID: ${child.pid}). Logs at /tmp/beetle-daemon.log`);
    process.exit(0);
  });

program.parse();
